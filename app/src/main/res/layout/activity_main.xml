<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/background_dark"
    tools:context="com.example.cvm.MainActivity">




    <FrameLayout
        android:id="@+id/warning_part"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_gravity="top"
        android:layout_weight="0"
        >

        <ImageView
            android:id="@+id/logo_img"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:scaleType="fitCenter"
            android:layout_margin="20dp"
            />

        <ImageView
            android:id="@+id/emergency_img"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            />

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="480dp"
            >

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="160dp">
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_weight="1">
                    <ImageView
                        android:id="@+id/left_light_img"
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:scaleType="fitXY"
                        android:layout_gravity="right"
                        />
                </FrameLayout>
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_weight="1">
                    <ImageView
                        android:id="@+id/straight_light_img"
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:scaleType="fitXY"
                        android:layout_gravity="center_horizontal"/>
                </FrameLayout>
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_weight="1">
                    <ImageView
                        android:id="@+id/right_light_img"
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:scaleType="fitXY"
                        android:layout_gravity="left"
                        />
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                >
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    >
                    <TextView
                        android:id="@+id/advise_speed_left"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="100dp"
                        android:textColor="@android:color/white"
                        android:textSize="30sp"
                        android:textStyle="bold"

                        android:textAlignment="center"
                        />

                    <TextView
                        android:id="@+id/advise_speed_straight"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="100dp"
                        android:textColor="@android:color/white"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:textAlignment="center"
                        />

                    <TextView
                        android:id="@+id/advise_speed_right"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="100dp"
                        android:textColor="@android:color/white"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:textAlignment="center"
                        />
                </LinearLayout>
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/warning_pic"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="100dp"
                        android:scaleType="centerInside"
                        android:layout_gravity="center_horizontal"/>


                    <TextView
                        android:id="@+id/warning_description"
                        android:layout_width="0dp"
                        android:layout_weight="3"
                        android:layout_height="100dp"
                        android:textColor="@android:color/white"
                        android:textSize="50sp"
                        android:textStyle="bold"
                        android:textAlignment="center"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            >

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="160dp"
                android:layout_weight="1">
                <TextView
                    android:id="@+id/left_light_time"
                    android:layout_width="160dp"
                    android:layout_height="80dp"
                    android:textColor="@android:color/white"
                    android:textSize="50sp"
                    android:textStyle="bold"
                    android:textAlignment="center"
                    android:layout_marginTop="40dp"
                    android:layout_gravity="right"
                    />
            </FrameLayout>
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="160dp"
                android:layout_weight="1">
                <TextView
                    android:id="@+id/straight_light_time"
                    android:layout_width="160dp"
                    android:layout_height="80dp"
                    android:textColor="@android:color/white"
                    android:textSize="50sp"
                    android:textStyle="bold"
                    android:textAlignment="center"
                    android:layout_marginTop="40dp"
                    android:layout_gravity="center_horizontal"
                    />
            </FrameLayout>
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="160dp"
                android:layout_weight="1">
                <TextView
                    android:id="@+id/right_light_time"
                    android:layout_width="160dp"
                    android:layout_height="80dp"
                    android:textColor="@android:color/white"
                    android:textSize="50sp"
                    android:textStyle="bold"
                    android:textAlignment="center"
                    android:layout_marginTop="40dp"
                    android:layout_gravity="left"
                    />
            </FrameLayout>
        </LinearLayout>


        <ImageView
            android:id="@+id/warning_sign_img"
            android:layout_marginTop="0dp"
            android:layout_width="wrap_content"
            android:layout_height="176dp"
            android:layout_gravity="center_horizontal"
            />

        <TextView
            android:id="@+id/warning_txv"
            android:layout_width="350dp"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:gravity="center"
            android:textColor="@android:color/white"
            android:textSize="55sp"
            android:textStyle="bold"
            />

    </FrameLayout>



    <FrameLayout
        android:id="@+id/driving_part"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0"
        android:layout_gravity="center_vertical">

        <ImageView
            android:id="@+id/road_img"
            android:layout_width="wrap_content"
            android:layout_height="430dp"
            android:layout_gravity="bottom"
            android:scaleType="fitXY"
            app:srcCompat="@drawable/road"
            />

        <ImageView
            android:id="@+id/car_img"
            android:layout_width="720dp"
            android:layout_height="320dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="120dp"
            app:srcCompat="@drawable/car"
            />


        <ImageView
            android:id="@+id/tip1_img"
            android:layout_width="123dp"
            android:layout_height="102dp"
            android:layout_marginTop="45dp"
            android:layout_marginLeft="430dp"
            />

        <ImageView
            android:id="@+id/tip2_img"
            android:layout_width="144dp"
            android:layout_height="150dp"
            android:layout_marginTop="45dp"
            android:layout_gravity="center_horizontal"
            />


    </FrameLayout>

    <FrameLayout
        android:id="@+id/map_part"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"
        android:layout_gravity="center_vertical">



        <com.amap.api.maps.MapView
            android:id="@+id/map"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <ImageView
            android:id="@+id/logo_background"
            android:layout_width="120dp"
            android:layout_height="48dp"
            android:scaleType="fitXY"
            android:layout_marginLeft="30dp"
            android:layout_marginTop="20dp"
            />

        <ImageView
            android:id="@+id/logo_img_new"
            android:layout_width="100dp"
            android:layout_height="48dp"
            android:scaleType="fitCenter"
            android:layout_marginTop="20dp"
            android:layout_marginLeft="40dp"
            />

<!--        <ImageView-->
<!--            android:id="@+id/warning_background"-->
<!--            android:layout_width="340dp"-->
<!--            android:layout_height="120dp"-->
<!--            android:scaleType="fitXY"-->
<!--            android:layout_marginLeft="160dp"-->
<!--            android:layout_marginTop="20dp"-->
<!--            />-->

        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="340dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_gravity="center_horizontal">
            <ImageView
                android:id="@+id/warning_pic_new"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="100dp"
                android:scaleType="centerInside"
                android:layout_gravity="center_horizontal"/>


            <TextView
                android:id="@+id/warning_description_new"
                android:layout_width="0dp"
                android:layout_weight="3"
                android:layout_height="match_parent"
                android:textColor="@android:color/black"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textAlignment="center"/>
        </LinearLayout>

<!--        <Button-->
<!--            android:id="@+id/mainMenu"-->
<!--            android:layout_width="100dp"-->
<!--            android:layout_height="100dp"-->
<!--            android:layout_gravity="right|top"-->
<!--            android:layout_marginTop="160dp"-->
<!--            android:layout_marginRight="10dp"-->
<!--            android:shadowColor="@color/colorPrimary"-->
<!--            android:background="@drawable/cvmbutton"-->
<!--            />-->

        <Button
            android:id="@+id/locate"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_gravity="bottom|right"
            android:layout_marginBottom="120dp"
            android:layout_marginRight="5dp"
            android:shadowColor="@color/colorPrimary"
            android:background="@drawable/locate"
            />

        <Button
            android:id="@+id/background_speed"
            android:layout_width="125dp"
            android:layout_height="125dp"
            android:layout_gravity="top|right"
            android:layout_marginTop="10dp"
            android:layout_marginRight="5dp"
            android:shadowColor="@color/colorPrimary"
            android:background="@drawable/background_speed"
            />

        <TextView
            android:id="@+id/host_speed"
            android:layout_width="125dp"
            android:layout_height="125dp"
            android:layout_gravity="top|right"
            android:layout_marginTop="10dp"
            android:layout_marginRight="5dp"
            android:gravity="center"
            android:textSize="25sp"
            android:textColor="#000000"
            android:elevation="10dp"
            />
    </FrameLayout>

</LinearLayout>